{
  "name": "my-virtual-office-nodejs",
  "version": "1.0.0",
  "description": "Node.js recreation of My Virtual Office with a live canvas office, agents, chat, dashboard, and editable layout.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:css && tsc",
    "build:css": "tailwindcss -i ./src/styles/daisyui.css -o ./public/daisyui.css --minify",
    "start": "npm run build && node server.js",
    "dev": "npm run build && node --watch server.js",
    "check": "npm run build && node --check server.js && node --check public/app.js && node --check public/agency.js",
    "templates:gallery": "node scripts/generate-template-gallery.mjs",
    "templates:refresh": "npm run templates:gallery && npm run build:css",
    "assets:placeholders": "node scripts/download-placeholder-images.mjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "nodemailer": "^9.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "daisyui": "^5.6.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2"
  }
}
